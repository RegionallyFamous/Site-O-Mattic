{
  "name": "site-o-mattic",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vinext dev",
    "build": "npm run blueprint:build && vinext build",
    "site:build": "vinext build",
    "start": "vinext start",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "blueprint:build:lawn": "node src/build-blueprint.mjs specs/lawn-care-service.json",
    "blueprint:build:pressure": "node src/build-blueprint.mjs specs/pressure-washing-service.json",
    "blueprint:build": "npm run blueprint:build:lawn && npm run blueprint:build:pressure",
    "blueprint:validate": "node src/validate-blueprint.mjs public/blueprints/lawn-care-service/blueprint.json public/blueprints/pressure-washing-service/blueprint.json",
    "blueprint:polish": "node src/polish-report.mjs public/blueprints/lawn-care-service/blueprint.json public/blueprints/pressure-washing-service/blueprint.json",
    "blueprint:variety": "node src/layout-variety-report.mjs public/blueprints/lawn-care-service/blueprint.json public/blueprints/pressure-washing-service/blueprint.json",
    "blueprint:visual": "node src/visual-qa.mjs",
    "validate": "npm run blueprint:validate",
    "quality": "npm run validate && npm run blueprint:polish && npm run blueprint:variety && npm run site:build && npm run lint",
    "render-brand": "sh scripts/render-brand-assets.sh"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "playwright-core": "^1.61.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  }
}
