{
  "name": "site-o-mattic",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vinext dev",
    "build": "npm run blueprint:build && npm run site:build",
    "site:build": "npm run app:sync && vinext build",
    "start": "vinext start",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "spec:validate": "node src/validate-specs.mjs",
    "blueprint:build": "node src/build-all-blueprints.mjs",
    "blueprint:validate": "node src/validate-blueprint.mjs",
    "blueprint:polish": "node src/polish-report.mjs",
    "blueprint:accessibility": "node src/accessibility-report.mjs",
    "blueprint:sync": "node src/signature-sync-report.mjs",
    "blueprint:variety": "node src/layout-variety-report.mjs",
    "blueprint:typography": "node src/typography-guardrails.mjs",
    "blueprint:guardrails": "node src/production-guardrails.mjs",
    "blueprint:asset-qa": "node src/asset-qa-report.mjs",
    "blueprint:copy-realism": "node src/copy-realism-report.mjs",
    "blueprint:premium": "node src/premium-review-report.mjs",
    "blueprint:visual": "node src/visual-qa.mjs",
    "fonts:catalog": "node src/google-fonts-catalog.mjs",
    "app:sync": "node src/sync-app-blueprints.mjs",
    "visual:baseline": "node src/visual-baseline-report.mjs",
    "visual:baseline:capture": "node src/capture-visual-baseline.mjs",
    "visual:sweep": "node src/visual-sweep.mjs",
    "visual:compare": "node src/visual-comparison-dashboard.mjs",
    "playground:smoke": "node src/public-playground-smoke.mjs",
    "spec:polish-fields": "node src/production-polish-fields.mjs",
    "validate": "npm run blueprint:validate",
    "quality": "npm run spec:validate && npm run validate && npm run blueprint:polish && npm run blueprint:accessibility && npm run blueprint:sync && npm run blueprint:variety && npm run blueprint:typography && npm run blueprint:guardrails && npm run blueprint:asset-qa && npm run blueprint:copy-realism && npm run blueprint:premium && npm run visual:baseline && npm run site:build && npm run lint",
    "render-brand": "sh scripts/render-brand-assets.sh"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "playwright-core": "^1.61.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  }
}
