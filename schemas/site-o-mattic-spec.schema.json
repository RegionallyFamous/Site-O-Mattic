{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regionallyfamous.com/site-o-mattic-spec.schema.json",
  "title": "Site-O-Mattic niche Blueprint spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "businessName",
    "niche",
    "layoutVariant",
    "pattern",
    "tagline",
    "themeSlug",
    "landingPage",
    "palette",
    "assets",
    "assetMeta",
    "contact",
    "copy",
    "services",
    "process",
    "proof",
    "brandBrief",
    "serviceDetails",
    "release"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "businessName": {
      "type": "string",
      "minLength": 3
    },
    "niche": {
      "type": "string",
      "minLength": 3
    },
    "layoutVariant": {
      "enum": [
        "route-plan",
        "before-after-quote",
        "checklist-urgency",
        "risk-prevention",
        "surface-seasonal",
        "stain-care",
        "side-rail-service",
        "side-rail-estimate",
        "gallery-led",
        "package-menu-board",
        "fixed-bottom-action",
        "bottom-dock-booking",
        "workshop-bench",
        "deck-finish-sample-board",
        "sharp-route-bench",
        "bike-route-workstand",
        "water-test-board",
        "zone-grid-planner",
        "organizing-zone-board",
        "route-led-schedule",
        "lawn-route-status-board",
        "urgent-checklist",
        "story-card-consult",
        "turnover-receipt-board",
        "service-receipt-stack",
        "window-scope-ledger",
        "pet-portrait-gallery",
        "street-food-menu-board",
        "dessert-table-gallery",
        "balloon-backdrop-gallery",
        "micro-wedding-floral-story",
        "photo-booth-strip-packages",
        "soundcheck-console",
        "picnic-proposal-lookbook",
        "mocktail-cart-menu",
        "headshot-proof-gallery",
        "mural-lettering-workshop",
        "color-consult-story",
        "furniture-refinish-proof"
      ]
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primaryPattern",
        "secondaryPattern",
        "silhouette",
        "navigationPrimitive",
        "mobileActionPattern",
        "imageRole",
        "imageEvidence",
        "ctaRhythm",
        "surfaceFamily",
        "surfaceModel",
        "styleFamily",
        "density",
        "colorRoles",
        "geometry",
        "coreBlockPlan",
        "knownRisks",
        "styleContract"
      ],
      "properties": {
        "primaryPattern": {
          "enum": [
            "decision-filter-route-plan",
            "route-schedule-board",
            "photo-quote-transformation",
            "checklist-urgency-gate",
            "risk-prevention-warning-path",
            "seasonal-readiness-estimate",
            "date-window-reservation",
            "soft-care-trust-plan",
            "operational-side-rail-console",
            "package-menu-board",
            "mobile-fixed-action-flow",
            "workshop-bench-photo-quote",
            "water-test-board-route",
            "zone-grid-planner",
            "gallery-led-portfolio-proof",
            "service-receipt-stack",
            "consultation-story-flow",
            "objection-led-faq-close"
          ]
        },
        "secondaryPattern": {
          "type": "string",
          "minLength": 3
        },
        "navigationPrimitive": {
          "enum": [
            "compact-header",
            "split-nav-action-header",
            "menu-utility-header",
            "desktop-side-rail",
            "split-side-top-hybrid",
            "section-anchor-strip",
            "fixed-bottom-mobile-cta",
            "floating-proof-action",
            "viewport-safe-hero-shell"
          ]
        },
        "imageRole": {
          "enum": [
            "work-in-progress",
            "finished-outcome",
            "process-closeup",
            "local-context",
            "proof-collage",
            "operator-or-founder",
            "environment-context"
          ]
        },
        "ctaRhythm": {
          "enum": [
            "call-first",
            "quote-first",
            "photo-first",
            "date-check",
            "package-select",
            "consult-first",
            "route-join",
            "book-first",
            "start-service",
            "photo-plan"
          ]
        },
        "surfaceModel": {
          "type": "string",
          "minLength": 3
        },
        "knownRisks": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 4
          }
        },
        "styleContract": {
          "type": "string",
          "minLength": 40
        },
        "silhouette": {
          "enum": [
            "viewport-safe-conversion-shell",
            "editorial-proof-stage",
            "split-quote-board",
            "receipt-scope-stack",
            "operator-console",
            "side-rail-service-story",
            "gallery-mosaic-proof",
            "checklist-urgency-gate",
            "route-status-board",
            "package-menu-board",
            "consultation-story-flow",
            "mobile-action-dock",
            "floating-proof-sidecar"
          ]
        },
        "mobileActionPattern": {
          "type": "string",
          "minLength": 3
        },
        "imageEvidence": {
          "type": "string",
          "minLength": 20
        },
        "surfaceFamily": {
          "enum": [
            "mostly-flat",
            "outlined-repeaters",
            "single-elevated-proof",
            "dark-panel",
            "receipt-stack",
            "ticket-menu-board",
            "grid-board",
            "gallery-mosaic",
            "mobile-dock",
            "side-rail",
            "status-board"
          ]
        },
        "styleFamily": {
          "enum": [
            "quiet-utility-grid",
            "humanist-local-calm",
            "editorial-proof-stage",
            "operator-console",
            "material-workbench",
            "mobile-action-gloss",
            "risk-control-alert",
            "receipt-ledger",
            "hospitality-menu",
            "clear-status-dashboard"
          ]
        },
        "density": {
          "enum": [
            "compact-leadgen",
            "balanced-editorial",
            "visual-first"
          ]
        },
        "colorRoles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ink",
            "paper",
            "field",
            "line",
            "primary",
            "action",
            "proof",
            "muted",
            "warning",
            "shadowTint"
          ],
          "properties": {
            "ink": {
              "type": "string",
              "minLength": 3
            },
            "paper": {
              "type": "string",
              "minLength": 3
            },
            "field": {
              "type": "string",
              "minLength": 3
            },
            "line": {
              "type": "string",
              "minLength": 3
            },
            "primary": {
              "type": "string",
              "minLength": 3
            },
            "action": {
              "type": "string",
              "minLength": 3
            },
            "proof": {
              "type": "string",
              "minLength": 3
            },
            "muted": {
              "type": "string",
              "minLength": 3
            },
            "warning": {
              "type": "string",
              "minLength": 3
            },
            "shadowTint": {
              "type": "string",
              "minLength": 3
            }
          }
        },
        "geometry": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "radiusScale",
            "borderRole",
            "shadowRole",
            "mediaCrop"
          ],
          "properties": {
            "radiusScale": {
              "type": "string",
              "minLength": 3
            },
            "borderRole": {
              "type": "string",
              "minLength": 3
            },
            "shadowRole": {
              "type": "string",
              "minLength": 3
            },
            "mediaCrop": {
              "type": "string",
              "minLength": 3
            }
          }
        },
        "coreBlockPlan": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": [
              "buttons",
              "columns",
              "cover",
              "details",
              "gallery",
              "image",
              "list",
              "media-text",
              "navigation",
              "quote",
              "pullquote",
              "table"
            ]
          }
        }
      }
    },
    "tagline": {
      "type": "string",
      "minLength": 8
    },
    "themeSlug": {
      "type": "string",
      "minLength": 3
    },
    "landingPage": {
      "type": "string",
      "pattern": "^/"
    },
    "palette": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grass",
        "deepGreen",
        "leaf",
        "sun",
        "cream",
        "mist",
        "soil",
        "white"
      ],
      "properties": {
        "grass": {
          "$ref": "#/$defs/hex"
        },
        "deepGreen": {
          "$ref": "#/$defs/hex"
        },
        "leaf": {
          "$ref": "#/$defs/hex"
        },
        "sun": {
          "$ref": "#/$defs/hex"
        },
        "cream": {
          "$ref": "#/$defs/hex"
        },
        "mist": {
          "$ref": "#/$defs/hex"
        },
        "soil": {
          "$ref": "#/$defs/hex"
        },
        "white": {
          "$ref": "#/$defs/hex"
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hero",
        "favicon"
      ],
      "properties": {
        "hero": {
          "type": "string"
        },
        "favicon": {
          "type": "string"
        }
      }
    },
    "assetMeta": {
      "type": "object",
      "required": [
        "hero"
      ],
      "properties": {
        "hero": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "title",
            "alt"
          ],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 8
            },
            "alt": {
              "type": "string",
              "minLength": 20
            }
          }
        }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phoneLabel",
        "phoneHref",
        "email",
        "emailHref",
        "serviceArea"
      ],
      "properties": {
        "phoneLabel": {
          "type": "string"
        },
        "phoneHref": {
          "type": "string",
          "pattern": "^tel:\\+?[0-9]+"
        },
        "email": {
          "type": "string"
        },
        "emailHref": {
          "type": "string",
          "pattern": "^mailto:"
        },
        "serviceArea": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "copy": {
      "type": "object",
      "required": [
        "eyebrow",
        "heroTitle",
        "heroText",
        "primaryCta",
        "secondaryCta",
        "introTitle",
        "introText",
        "servicesTitle",
        "processTitle",
        "proofTitle",
        "quoteTitle",
        "quoteText"
      ]
    },
    "services": {
      "$ref": "#/$defs/cardArray"
    },
    "process": {
      "$ref": "#/$defs/cardArray"
    },
    "proof": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stat",
          "label"
        ],
        "properties": {
          "stat": {
            "type": "string",
            "minLength": 2
          },
          "label": {
            "type": "string",
            "minLength": 8
          }
        }
      }
    },
    "brandBrief": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mood",
        "trustCue",
        "accentBehavior",
        "imageProof",
        "signatureMove",
        "avoidLookingLike"
      ],
      "properties": {
        "mood": {
          "type": "string",
          "minLength": 12
        },
        "trustCue": {
          "type": "string",
          "minLength": 10
        },
        "accentBehavior": {
          "type": "string",
          "minLength": 18
        },
        "imageProof": {
          "type": "string",
          "minLength": 18
        },
        "signatureMove": {
          "type": "string",
          "minLength": 10
        },
        "avoidLookingLike": {
          "type": "string",
          "minLength": 18
        }
      }
    },
    "serviceDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turnaround",
        "whatToSend",
        "prepNote",
        "serviceRhythm",
        "objectionAnswer"
      ],
      "properties": {
        "turnaround": {
          "type": "string",
          "minLength": 28
        },
        "whatToSend": {
          "type": "string",
          "minLength": 28
        },
        "prepNote": {
          "type": "string",
          "minLength": 28
        },
        "serviceRhythm": {
          "type": "string",
          "minLength": 28
        },
        "objectionAnswer": {
          "type": "string",
          "minLength": 28
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reviewedAt",
        "visualBaseline",
        "reviewChecklist",
        "premiumReview"
      ],
      "properties": {
        "status": {
          "enum": [
            "draft",
            "approved",
            "published"
          ]
        },
        "reviewedAt": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "visualBaseline": {
          "enum": [
            "pending",
            "approved"
          ]
        },
        "reviewChecklist": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "firstViewportClear",
            "textBrandReadable",
            "layoutDistinct",
            "ctaClear",
            "copySpecific",
            "noImageArtifacts",
            "heroArtDirected",
            "hierarchyDistinct",
            "signatureMove",
            "restrainedComposition",
            "screenshotCompared"
          ],
          "properties": {
            "firstViewportClear": {
              "type": "boolean"
            },
            "textBrandReadable": {
              "type": "boolean"
            },
            "layoutDistinct": {
              "type": "boolean"
            },
            "ctaClear": {
              "type": "boolean"
            },
            "copySpecific": {
              "type": "boolean"
            },
            "noImageArtifacts": {
              "type": "boolean"
            },
            "heroArtDirected": {
              "type": "boolean"
            },
            "hierarchyDistinct": {
              "type": "boolean"
            },
            "signatureMove": {
              "type": "boolean"
            },
            "restrainedComposition": {
              "type": "boolean"
            },
            "screenshotCompared": {
              "type": "boolean"
            }
          }
        },
        "premiumReview": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "version",
            "reviewedAt",
            "score",
            "categories",
            "notes"
          ],
          "properties": {
            "version": {
              "const": 2
            },
            "reviewedAt": {
              "type": "string",
              "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
            },
            "score": {
              "type": "number",
              "minimum": 90,
              "maximum": 100
            },
            "categories": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "firstViewport",
                "brandText",
                "typography",
                "polishContract",
                "imageProof",
                "ctaClarity",
                "mobilePolish",
                "layoutDistinctness",
                "copySpecificity",
                "assetQa",
                "brandBrief"
              ],
              "properties": {
                "firstViewport": {
                  "type": "boolean"
                },
                "brandText": {
                  "type": "boolean"
                },
                "typography": {
                  "type": "boolean"
                },
                "polishContract": {
                  "type": "boolean"
                },
                "imageProof": {
                  "type": "boolean"
                },
                "ctaClarity": {
                  "type": "boolean"
                },
                "mobilePolish": {
                  "type": "boolean"
                },
                "layoutDistinctness": {
                  "type": "boolean"
                },
                "copySpecificity": {
                  "type": "boolean"
                },
                "assetQa": {
                  "type": "boolean"
                },
                "brandBrief": {
                  "type": "boolean"
                }
              }
            },
            "notes": {
              "type": "array",
              "minItems": 3,
              "items": {
                "type": "string",
                "minLength": 8
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "hex": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "cardArray": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "text"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 3
          },
          "text": {
            "type": "string",
            "minLength": 20
          }
        }
      }
    }
  }
}
